{
  "name": "vng-interactie-apis",
  "author": {
    "name": "Joep Meindertsma"
  },
  "version": "1.0.0",
  "description": "VNG Interactie APIs and Schemas",
  "scripts": {
    "lint": "spectral lint \"apis/**/*.yaml\"",
    "prep-docs": "node scripts/generate-portal-data.js",
    "dev": "pnpm prep-docs && concurrently \"vite\" \"pnpm mock\"",
    "build": "pnpm prep-docs && vite build && cp -R docs apis schemas patterns *.md dist/",
    "serve": "pnpm build && npx serve dist",
    "mock": "node scripts/mock-all.js"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "@xyflow/react": "^12.0.0",
    "marked": "^15.0.0"
  },
  "devDependencies": {
    "@scalar/cli": "latest",
    "@stoplight/prism-cli": "^5.11.0",
    "@stoplight/spectral-cli": "^6.11.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.2",
    "express": "^5.2.1",
    "fast-glob": "^3.3.3",
    "http-proxy-middleware": "^3.0.5",
    "js-yaml": "^4.1.1",
    "serve": "^14.2.0",
    "vite": "^5.0.0"
  }
}
