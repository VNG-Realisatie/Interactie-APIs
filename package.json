{
  "name": "vng-apis-schemas",
  "author": {
    "name": "Joep Meindertsma"
  },
  "version": "1.0.0",
  "description": "VNG API Standards and Schemas",
  "scripts": {
    "lint": "spectral lint \"apis/**/*.yaml\" \"schemas/**/*.json\" \"patterns/**/*.yaml\"",
    "prep-docs": "node scripts/generate-portal-data.js",
    "serve": "pnpm prep-docs && echo '\n🚀 API Portal: http://localhost:3000/docs/\n' && npx serve .",
    "mock": "node scripts/mock-all.js",
    "dev": "pnpm prep-docs && npx concurrently \"npm run serve\" \"npm run mock\""
  },
  "devDependencies": {
    "@scalar/cli": "latest",
    "@stoplight/prism-cli": "^5.11.0",
    "@stoplight/spectral-cli": "^6.11.0",
    "concurrently": "^8.2.2",
    "express": "^5.2.1",
    "fast-glob": "^3.3.3",
    "http-proxy-middleware": "^3.0.5",
    "js-yaml": "^4.1.1",
    "serve": "^14.2.0"
  }
}
