{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Adres",
  "type": "object",
  "properties": {
    "straatnaam": {
      "type": "string",
      "example": "Wilhelminaplein"
    },
    "huisnummer": {
      "type": "integer",
      "example": 1
    },
    "postcode": {
      "type": "string",
      "pattern": "^[1-9][0-9]{3}[A-Z]{2}$",
      "example": "1234AB"
    },
    "woonplaats": {
      "type": "string",
      "example": "Utrecht"
    }
  },
  "required": [
    "straatnaam",
    "huisnummer",
    "postcode",
    "woonplaats"
  ],
  "x-vng-status": "stable"
}
