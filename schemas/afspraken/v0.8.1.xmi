		<EAModel.defect>
			<EADefect name="Aanpassen groepattributen " description="&#xa;Stel vast welke criteria onderkend worden voor groepattributen en pas deze toe op de onderkende groepattributen " type="Change" subject="EAID_BF048309_078D_5E21_8C48_CF47B48AE39B">
				<UML:ModelElement.taggedValue>
					<UML:TaggedValue tag="datereported" value="2010-12-17 11:01:07"/>
					<UML:TaggedValue tag="status" value="Complete"/>
					<UML:TaggedValue tag="priority" value="High"/>
					<UML:TaggedValue tag="reportedby" value="Metamodel"/>
					<UML:TaggedValue tag="resolvedby" value="Ellen Debats"/>
					<UML:TaggedValue tag="dateresolved" value="2011-02-10 07:40:05"/>
					<UML:TaggedValue tag="version" value="2.01"/>
					<UML:TaggedValue tag="resolvernote" value="Criteria voor toepassing van groepatrtributen zijn opgesteld. Zie aldaar.&#xa;Zie excel spreadsheet   &quot;Voorstel modellering RSGB groepattributen&quot; voor oplossingsrichting.&#xa;Conform spreadsheet doorgevoerd in het model. "/>
				</UML:ModelElement.taggedValue>
			</EADefect>
			<EADefect name="Adres NP in buitenland heeft meer adresregels" description="NP in BRP kan voor buitenlandsadres 6 adresregels hebben: &#xa;adres regel buitenland uitgebreid van 3 naar 6" type="Change" subject="EAID_BF048309_078D_5E21_8C48_CF47B48AE39B">
				<UML:ModelElement.taggedValue>
					<UML:TaggedValue tag="datereported" value="2015-02-06 11:01:07"/>
					<UML:TaggedValue tag="status" value="Complete"/>
					<UML:TaggedValue tag="priority" value="Medium"/>
					<UML:TaggedValue tag="reportedby" value="BRP"/>
					<UML:TaggedValue tag="resolvedby" value="Remko de Haas"/>
					<UML:TaggedValue tag="dateresolved" value="2015-02-06 07:40:05"/>
					<UML:TaggedValue tag="version" value="3.0"/>
				</UML:ModelElement.taggedValue>
			</EADefect>
			<EADefect name="Code attribuutsoort dubbel gebruikt" description="Adres buitenland 1 en Adres buitenland 2 kennen dezelfde code attribuutsoort. Die moet uniek zijn. Vermodelijk geldt voor 2 de code 40 ipv 30." type="Issue" subject="EAID_BF048309_078D_5E21_8C48_CF47B48AE39B">
				<UML:ModelElement.taggedValue>
					<UML:TaggedValue tag="datereported" value="2010-07-05 09:58:14"/>
					<UML:TaggedValue tag="status" value="Complete"/>
					<UML:TaggedValue tag="priority" value="Medium"/>
					<UML:TaggedValue tag="reportedby" value="Harmonisatie NEN3610"/>
					<UML:TaggedValue tag="resolvedby" value="Harmen Mantel"/>
					<UML:TaggedValue tag="dateresolved" value="2010-12-03 13:14:21"/>
					<UML:TaggedValue tag="version" value="2.01"/>
					<UML:TaggedValue tag="resolvernote" value="(03DEC10) aangepast naar 40, opgelost"/>
				</UML:ModelElement.taggedValue>
			</EADefect>
			<EADefect name="Geen type specificatie" description="Geldt voor:&#xa;&#xa;- Adres buitenland 1&#xa;- Adres buitenland 2&#xa;- Adres buitenland 3" type="Issue" subject="EAID_BF048309_078D_5E21_8C48_CF47B48AE39B">
				<UML:ModelElement.taggedValue>
					<UML:TaggedValue tag="datereported" value="2010-07-05 09:58:14"/>
					<UML:TaggedValue tag="status" value="Complete"/>
					<UML:TaggedValue tag="priority" value="Medium"/>
					<UML:TaggedValue tag="reportedby" value="Harmonisatie NEN3610"/>
					<UML:TaggedValue tag="resolvedby" value="Ellen Debats"/>
					<UML:TaggedValue tag="dateresolved" value="2011-03-01 11:22:12"/>
					<UML:TaggedValue tag="version" value="2.01"/>
					<UML:TaggedValue tag="resolvernote" value="(03DEC10) Zie Stuf en/of GBA"/>
				</UML:ModelElement.taggedValue>
			</EADefect>
			<EADefect name="Indicatie authentiek attribuutsoorten / relatiesoorten" description="Eenduidigheid aangebracht. Er zijn nu vijf mogelijkheden: Authentiek gegeven, Basisgegeven, Landelijk kerngegeven, Gemeentelijk kerngegeven en Overig. &#xa;&#xa;&#xa;&#xa;" type="Change" subject="EAID_BF048309_078D_5E21_8C48_CF47B48AE39B">
				<UML:ModelElement.taggedValue>
					<UML:TaggedValue tag="datereported" value="2013-11-28 11:01:07"/>
					<UML:TaggedValue tag="status" value="Complete"/>
					<UML:TaggedValue tag="priority" value="High"/>
					<UML:TaggedValue tag="reportedby" value="Metamodel"/>
					<UML:TaggedValue tag="resolvedby" value="Ellen Debats"/>
					<UML:TaggedValue tag="dateresolved" value="2013-11-28 07:40:05"/>
					<UML:TaggedValue tag="version" value="3.0"/>
					<UML:TaggedValue tag="resolvernote" value="Bij een attribuutsoort of relatiesoort wordt als metagegeven de ‘Indicatie authentiek’ opgenomen. Het is een aanduiding of een attribuutsoort of een als relatiesoort gemodelleerd landelijk basisgegeven in de catalogus van de desbetreffende basisregistratie een authentiek gegeven betreft. We hebben niet gespecificeerd welke waarden onderkend worden van dit metagegeven.  Op dit moment wordt dit metagegeven binnen de modellen niet eenduidig gespecificeerd.&#xa;Specificatie metagegeven is conform afpraken expertgroep informatiemodellen 12 september 2013 doorgevoerd in model."/>
				</UML:ModelElement.taggedValue>
			</EADefect>
			<EADefect name="Relatiesoort onduidelijk" description="SUBJECT heeft verblijfsadres in LAND. Hoe t.o.v. objecttype Subject?" type="Issue" subject="EAID_BF048309_078D_5E21_8C48_CF47B48AE39B">
				<UML:ModelElement.taggedValue>
					<UML:TaggedValue tag="datereported" value="2010-07-05 09:58:14"/>
					<UML:TaggedValue tag="status" value="Complete"/>
					<UML:TaggedValue tag="reportedby" value="Harmonisatie NEN3610"/>
					<UML:TaggedValue tag="resolvedby" value="Arjan Kloosterboer"/>
					<UML:TaggedValue tag="dateresolved" value="2023-01-23 12:29:00"/>
					<UML:TaggedValue tag="version" value="2.01"/>
					<UML:TaggedValue tag="resolvernote" value="(03DEC10) Betreft de situatie waarbij groepattributen verspreid zijn over de generatlisaties EN specialisaties. Al eerder genoemd. We gaan de constructie naast elkaar zetten (overerving en aggregatie) en kiezen de beste constructiue."/>
				</UML:ModelElement.taggedValue>
			</EADefect>
			<EADefect name="BRP objecttype LAND" description="Bestaat al in RSGB&#xa;Controleren of definities e.d. aangepast moeten worden!" type="Issue" subject="EAID_BCB3B056_E1B6_9CBE_8BE8_4611A8A52EAE">
				<UML:ModelElement.taggedValue>
					<UML:TaggedValue tag="datereported" value="2012-07-31 11:41:54"/>
					<UML:TaggedValue tag="status" value="New"/>
					<UML:TaggedValue tag="priority" value="High"/>
					<UML:TaggedValue tag="reportedby" value="BRP"/>
					<UML:TaggedValue tag="dateresolved" value="2023-02-27 11:10:53"/>
					<UML:TaggedValue tag="version" value="3.0"/>
				</UML:ModelElement.taggedValue>
			</EADefect>
			<EADefect name="Buiten scope" description="Dit specificeert de landentabel maar we willen hier alleen een identicerende waarde van een land vasthouden.&#xa;De landentabel is geen onderdeel van RSGB (maar waarvan dan wel?). &#xa;&#xa;Voorstel is dit objecttype te verwijderen en te vervangen met een identificerend attribuut in het source element van de (te vervallen) relatiesoort.&#xa;&#xa;Welk identificerend attribuut? Dan moeten we eerst weten waarom we een landentabel GBA hebben. De voorkeur gaat uit naar Landcode ISO (internationaal en waarschijnlijk eigenaar)." type="Issue" subject="EAID_BCB3B056_E1B6_9CBE_8BE8_4611A8A52EAE">
				<UML:ModelElement.taggedValue>
					<UML:TaggedValue tag="datereported" value="2011-01-04 11:41:54"/>
					<UML:TaggedValue tag="status" value="Complete"/>
					<UML:TaggedValue tag="priority" value="High"/>
					<UML:TaggedValue tag="reportedby" value="Ellen Debats"/>
					<UML:TaggedValue tag="resolvedby" value="Ellen Debats"/>
					<UML:TaggedValue tag="dateresolved" value="2011-02-14 11:22:12"/>
					<UML:TaggedValue tag="version" value="2.01"/>
					<UML:TaggedValue tag="resolvernote" value="Is onderkend als een referentielijst. Deze lijst wordt door een centrale instantie beheerd."/>
				</UML:ModelElement.taggedValue>
			</EADefect>
			<EADefect name="Hernoemt naar LAND/GEBIED" type="Change" subject="EAID_BCB3B056_E1B6_9CBE_8BE8_4611A8A52EAE">
				<UML:ModelElement.taggedValue>
					<UML:TaggedValue tag="datereported" value="2015-06-30 20:26:01"/>
					<UML:TaggedValue tag="status" value="Complete"/>
					<UML:TaggedValue tag="priority" value="Low"/>
					<UML:TaggedValue tag="reportedby" value="BRP"/>
					<UML:TaggedValue tag="resolvedby" value="Remko de Haas"/>
					<UML:TaggedValue tag="dateresolved" value="2015-06-30 07:40:05"/>
					<UML:TaggedValue tag="version" value="3.0"/>
				</UML:ModelElement.taggedValue>
			</EADefect>
			<EADefect name="Referentielijst LAND (voorheen objecttype LAND)" description="Objecttype is vervangen door referentielijst." type="Change" subject="EAID_BCB3B056_E1B6_9CBE_8BE8_4611A8A52EAE">
				<UML:ModelElement.taggedValue>
					<UML:TaggedValue tag="datereported" value="2011-01-14 20:26:01"/>
					<UML:TaggedValue tag="status" value="Complete"/>
					<UML:TaggedValue tag="priority" value="High"/>
					<UML:TaggedValue tag="reportedby" value="Metamodel"/>
					<UML:TaggedValue tag="resolvedby" value="Ellen Debats"/>
					<UML:TaggedValue tag="dateresolved" value="2011-02-14 07:40:05"/>
					<UML:TaggedValue tag="version" value="2.01"/>
					<UML:TaggedValue tag="resolvernote" value="Binnen het RSGB is een aantal objecttypen te onderkennen die duidelijk voldoen aan de criteria van een referentielijst (zie &lt;a href=&quot;$element://{60263E60-0411-4a2c-9BBE-D78248EB2B70}&quot;>&lt;font color=&quot;#0000ff&quot;>&lt;u>Toepassingscriteria / regels modelelementen&lt;/u>&lt;/font>&lt;/a>)."/>
				</UML:ModelElement.taggedValue>
			</EADefect>
			<EADefect name="Tagged value objecttype niet ingevuld" description="Betreft:&#xa;&#xa;- Toelichting objecttype" type="Issue" subject="EAID_BCB3B056_E1B6_9CBE_8BE8_4611A8A52EAE">
				<UML:ModelElement.taggedValue>
					<UML:TaggedValue tag="datereported" value="2010-12-16 11:41:54"/>
