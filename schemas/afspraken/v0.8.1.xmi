		<UML:TaggedValue tag="Definitie" xmi.id="EAID_5F3916B1_2792_1627_A41C_851FF7942E17" value="#NOTES#Description: De beschrijving van de betekenis van dit modelelement.&#xa;" modelElement="MX_EAID_8E31EAF7_88F8_BF27_8AD1_6729B6EEF32D"/>
		<UML:TaggedValue tag="Herkomst" xmi.id="EAID_6B33862D_7EEE_517e_B098_D4C85CC99419" value="#NOTES#Description: De registratie of het informatiemodel waaraan het modelelement ontleend is dan wel de eigen organisatie indien het door de eigen organisatie toegevoegd is.&#xa;" modelElement="MX_EAID_8E31EAF7_88F8_BF27_8AD1_6729B6EEF32D"/>
		<UML:TaggedValue tag="Imvertor" xmi.id="EAID_C83112F8_0BB9_4f0b_8C5B_FA866329ADA6" value="model#NOTES#Values: model&#xa;Default: model&#xa;Description: Deze waarde geeft aan dat het pakket een volledig model is dat kan worden verwerkt door de Imvertor-software. Deze waarde is vereist door de Imvertor add-in op Enterprise Architect.&#xa;" modelElement="MX_EAID_8E31EAF7_88F8_BF27_8AD1_6729B6EEF32D"/>
		<UML:TaggedValue tag="Informatiedomein" xmi.id="EAID_4C9B034A_2D0B_022d_AEA9_2FE6B49F8B17" value="#NOTES#Description: Aanduiding van het functionele domein waartoe het informatiemodel behoort.&#xa;" modelElement="MX_EAID_8E31EAF7_88F8_BF27_8AD1_6729B6EEF32D"/>
		<UML:TaggedValue tag="Informatiemodel type" xmi.id="EAID_356BE6A1_08E2_e408_9CE6_2526A4EE24D6" value="Conceptueel#NOTES#Values: Conceptueel,Logisch&#xa;Default: Conceptueel&#xa;Description: De beschrijving van de aard van het informatiemodel, hoe het geïnterpreteerd moet worden.&#xa;" modelElement="MX_EAID_8E31EAF7_88F8_BF27_8AD1_6729B6EEF32D"/>
		<UML:TaggedValue tag="Is afgeleid" xmi.id="EAID_3B9D7FED_4D0E_024d_9DE2_F2AC82E83B83" value="Zie package#NOTES#Values: Ja,Nee,Zie package&#xa;Default: Zie package&#xa;Description: Deze constructie is al dan niet afgeleid van een &quot;supplier model&quot;. Wanneer je niks opgeeft wordt afleiding vastgesteld op basis van het package waarin het voorkomt.&#xa;" modelElement="MX_EAID_8E31EAF7_88F8_BF27_8AD1_6729B6EEF32D"/>
		<UML:TaggedValue tag="MIM extensie" xmi.id="EAID_33F0D908_7E09_067e_B5C6_2CA5E07F6129" value="#NOTES#Description: De aanduiding van een extensie op MIM.&#xa;" modelElement="MX_EAID_8E31EAF7_88F8_BF27_8AD1_6729B6EEF32D"/>
		<UML:TaggedValue tag="MIM taal" xmi.id="EAID_2B713125_7DA6_a27d_8191_51264002A8AD" value="NL#NOTES#Values: EN,NL&#xa;Default: NL&#xa;Description: De aanduiding van de taal die gebruikt is voor de modelelementen.&#xa;" modelElement="MX_EAID_8E31EAF7_88F8_BF27_8AD1_6729B6EEF32D"/>
		<UML:TaggedValue tag="MIM versie" xmi.id="EAID_D17E3FD1_B092_34b0_9CB9_E302EFF3EA9B" value="1.1#NOTES#Values: 1.1&#xa;Default: 1.1&#xa;Description: De versie van de MIM specificatie die gebruikt is om het informatiemodel in uit te drukken.&#xa;" modelElement="MX_EAID_8E31EAF7_88F8_BF27_8AD1_6729B6EEF32D"/>
		<UML:TaggedValue tag="Niveau" xmi.id="EAID_0845F168_C5E9_5cc5_AB26_D3F50C14F7D5" value="specifiek#NOTES#Values: generiek,specifiek&#xa;Default: specifiek&#xa;Description: Het niveau is een waarde uit een beperkte set: &quot;algemeen&quot; betekent dat het model een fundament is van een ander model en moet worden opgenomen. Het modelleert generieke constructies die deel uitmaken van de echte wereld. Dit omvat meestal abstracte object typen. Het kan andere constructen bevatten. &quot;specifiek&quot; betekent dat het model een bepaald domein beschrijft of een samenhangend deel ervan .&#xa;" modelElement="MX_EAID_8E31EAF7_88F8_BF27_8AD1_6729B6EEF32D"/>
		<UML:TaggedValue tag="Relatiemodelleringstype" xmi.id="EAID_74E5C28D_492E_2649_A444_493961DD0CE5" value="Relatiesoort leidend#NOTES#Values: Relatierol leidend,Relatiesoort leidend&#xa;Default: Relatiesoort leidend&#xa;Description: Aanduiding van een in MIM gedefinieerd alternatief voor een modelleringswijze, en welke keuze hierbij is gemaakt.&#xa;" modelElement="MX_EAID_8E31EAF7_88F8_BF27_8AD1_6729B6EEF32D"/>
		<UML:TaggedValue tag="release" xmi.id="EAID_3502C69F_0C4B_43d6_BD98_4976B2C3980C" value="20260413" modelElement="MX_EAID_8E31EAF7_88F8_BF27_8AD1_6729B6EEF32D"/>
