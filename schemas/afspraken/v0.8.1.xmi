															<XMI.extension xmi.extender="Enterprise Architect 2.5">
																<UML:Comment name=" De basisregistratie in wiens catalogus het objecttype is gespecificeerd (oftewel de basisregistratie waar het objecttype deel van uitmaakt). Deze specificatie is toegevoegd omdat het wel duidelijk moet zijn in welke (basis)registratie of informatiemodel het objecttype voorkomt (indien van toepassing).&#xa;"/>
															</XMI.extension>
														</UML:TaggedValue>
														<UML:TaggedValue tag="Herkomst definitie" value="Dienstverlening - MijnServices - MijnAgenda" xmi.id="EAID_1FAA1D3E_BF77_50bf_82B0_E944C15CC9D4">
															<XMI.extension xmi.extender="Enterprise Architect 2.5">
