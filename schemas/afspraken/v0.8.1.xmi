													<UML:ModelElement.taggedValue>
														<UML:TaggedValue tag="description" value="Per activiteitsoort het aantal daarvan op de agenda-afspraak.&#xa;&#xa;Voorbeelden:&#xa;&lt;ul>&#xa;&#x9;&lt;li>Als de activiteitsoort is uitgesplitst, dan per activiteitsoort het aantal (bijv. 2 paspoorten aanvragen)&lt;/li>&#xa;&#x9;&lt;li>Als de activiteitsoort is samengesteld, dan aantal op 1 houden.&lt;/li>&#xa;&lt;/ul>"/>
