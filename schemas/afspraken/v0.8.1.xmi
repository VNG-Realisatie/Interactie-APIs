															</XMI.extension>
														</UML:TaggedValue>
														<UML:TaggedValue tag="Herkomst" xmi.id="EAID_6B33862D_5D26_aa5d_99E0_47F8DF98A75D">
															<XMI.extension xmi.extender="Enterprise Architect 2.5">
																<UML:Comment name="Description: De basisregistratie in wiens catalogus het objecttype is gespecificeerd (oftewel de basisregistratie waar het objecttype deel van uitmaakt). Deze specificatie is toegevoegd omdat het wel duidelijk moet zijn in welke (basis)registratie of informatiemodel het objecttype voorkomt (indien van toepassing).&#xa;"/>
															</XMI.extension>
														</UML:TaggedValue>
														<UML:TaggedValue tag="Herkomst definitie" value="Dienstverlening - MijnServices - MijnAgenda" xmi.id="EAID_1FAA1D3E_BF77_50bf_8A31_CC8F7D914B09">
															<XMI.extension xmi.extender="Enterprise Architect 2.5">
																<UML:Comment name=" De basisregistratie of het informatiemodel waaruit de definitie is overgenomen dan wel een aanduiding die aangeeft uit welke bronnen de defintie is samengesteld.&#xa;"/>
															</XMI.extension>
														</UML:TaggedValue>
														<UML:TaggedValue tag="Indicatie afleidbaar" xmi.id="EAID_E7872985_3DFE_5f3d_8436_ED8076DBC02C">
															<XMI.extension xmi.extender="Enterprise Architect 2.5">
																<UML:Comment name="Description: Aanduiding dat gegeven afleidbaar is uit andere attribuut- en/of relatiesoorten.&#xa;"/>
															</XMI.extension>
														</UML:TaggedValue>
														<UML:TaggedValue tag="Indicatie classificerend" xmi.id="EAID_516262A9_0BA2_b20b_AFEE_2BD082383017">
															<XMI.extension xmi.extender="Enterprise Architect 2.5">
																<UML:Comment name="Description: Indicatie dat een attribuutsoort het objecttype waar het bijhoort classificeert in (sub)typen.&#xa;"/>
															</XMI.extension>
														</UML:TaggedValue>
														<UML:TaggedValue tag="Indicatie formele historie" value="Nee" xmi.id="EAID_D0DCC9FB_9534_ba95_808E_391A53A50AFD">
															<XMI.extension xmi.extender="Enterprise Architect 2.5">
																<UML:Comment name="Values: Ja,Nee,Zie groep,N.v.t.&#xa;Default: Nee&#xa;Description: Indicatie of de formele historie van de attribuutsoort te bevragen is. Formele historie geeft aan wanneer in de administratie een verandering is verwerkt van de attribuutwaarde (wanneer was de verandering bekend en is deze verwerkt).&#xa;"/>
															</XMI.extension>
														</UML:TaggedValue>
														<UML:TaggedValue tag="Indicatie in onderzoek" value="Nee" xmi.id="EAID_97BB8112_97CB_ea97_B90B_FBFBC1212B4F">
															<XMI.extension xmi.extender="Enterprise Architect 2.5">
																<UML:Comment name="Values: Ja,Nee,Zie groep&#xa;Default: Nee&#xa;Description: De indicatie of te bevragen is dat er twijfel is of is geweest aan de juistheid van de attribuutwaarde en dat een onderzoek wordt of is uitgevoerd naar de juistheid van de attribuutwaarde.&#xa;"/>
															</XMI.extension>
														</UML:TaggedValue>
														<UML:TaggedValue tag="Indicatie materiële historie" value="Nee" xmi.id="EAID_8F70DA6F_57E8_ee57_9C68_A2DE1B009D84">
															<XMI.extension xmi.extender="Enterprise Architect 2.5">
																<UML:Comment name="Values: Ja,Nee,Zie groep,zie regels,N.v.t.&#xa;Default: Nee&#xa;Description: Indicatie of de materiële historie van de attribuutsoort te bevragen is. Materiële historie geeft aan wanneer een verandering is opgetreden in de werkelijkheid die heeft geleid tot veranderjng van de attribuutwaarde.&#xa;"/>
															</XMI.extension>
														</UML:TaggedValue>
														<UML:TaggedValue tag="Is afgeleid" value="Zie package" xmi.id="EAID_3B9D7FED_2046_3520_BF99_97E472362C36">
															<XMI.extension xmi.extender="Enterprise Architect 2.5">
																<UML:Comment name="Values: Nee,Ja,Zie package&#xa;Default: Zie package&#xa;Description: Deze constructie is al dan niet afgeleid van een &quot;supplier model&quot;. Wanneer je niks opgeeft wordt afleiding vastgesteld op basis van het package waarin het voorkomt.&#xa;"/>
															</XMI.extension>
														</UML:TaggedValue>
														<UML:TaggedValue tag="Lengte" xmi.id="EAID_034EE5FF_AAB8_01aa_82A3_35ACEC936E39">
