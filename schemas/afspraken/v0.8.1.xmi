													</UML:StructuralFeature.type>
													<UML:ModelElement.stereotype>
														<UML:Stereotype name="Attribuutsoort"/>
													</UML:ModelElement.stereotype>
													<UML:ModelElement.taggedValue>
														<UML:TaggedValue tag="description" value="De naam van de activiteitsoort.&#xa;&#xa;Bijv. als het aantal activiteitsoorten aangeduid kan worden in de relatieklasse ACTIVITEITSOORT OP AFSPRAAK:&#xa;&lt;ul>&#xa;&#x9;&lt;li>Verlengen paspoort&lt;/li>&#xa;&#x9;&lt;li>Aanvragen ID-kaart&lt;/li>&#xa;&lt;/ul>&#xa;&#xa;Bijv. als het aantal activiteitsoorten aangeduid niet kan worden in de relatieklasse ACTIVITEITSOORT OP AFSPRAAK:&#xa;&lt;ul>&#xa;&#x9;&lt;li>Verlengen paspoort 2x&lt;/li>&#xa;&#x9;&lt;li>Aanvragen ID-kaart 1x&lt;/li>&#xa;&lt;/ul>&#xa;&#xa;Bijv. als de activiteitsoort niet netjes uitgesplist kan worden:&#xa;&lt;ul>&#xa;&#x9;&lt;li>Verlengen paspoort (2x), aanvragen ID-kaart (1x)&lt;/li>&#xa;&lt;/ul>"/>
