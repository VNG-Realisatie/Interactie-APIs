											<UML:ModelElement.taggedValue>
												<UML:TaggedValue tag="documentation" value="De activiteitsoorten op een agenda-afspraak.&#xa;Bijv. een agenda-afspraak voor:&#xa;&lt;ul>&#xa;&#x9;&lt;li>1x het initieel aanvragen van een ID-kaart, en&lt;/li>&#xa;&#x9;&lt;li>2x verlengen van paspoort.&lt;/li>&#xa;&lt;/ul>&#xa;&#xa;Als de activiteitsoort is uitgesplitst, kan hier het daadwerkelijke aantal worden aangeduid."/>
												<UML:TaggedValue tag="isSpecification" value="false"/>
